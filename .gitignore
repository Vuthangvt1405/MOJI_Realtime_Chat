# Keep repository focused on application folders
/*
!/backend/
!/frontend/
!/.github/
!/.github/workflows/
!/.gitignore
!/README.md
!/render.yaml

# Dependencies and build output
**/node_modules/
**/dist/
**/dist-ssr/

# Environment files and secrets
**/.env
**/.env.*
!**/.env.example

# Logs
**/logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Local/editor files
*.local
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.serena
opencode.jsonc
.understand-anything
.gitnexus
